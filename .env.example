# taxback365 환경변수 템플릿
# 이 파일은 git에 커밋된다. 실제 값은 .env.local에 채우거나 Vercel 환경변수에 등록.
# .env.local은 .gitignore의 *.local 패턴으로 자동 제외.

# ============================================================
# NextAuth (필수)
# ============================================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# `openssl rand -base64 32` 또는 PowerShell 동등 명령으로 32바이트 이상 랜덤값 생성.
NEXTAUTH_SECRET=
# 로컬 dev 기본 http://localhost:3001, Vercel은 도메인 자동 주입.
NEXTAUTH_URL=http://localhost:3001

# ============================================================
# Supabase (필수)
# ============================================================
# 클라이언트/공개. 브라우저 번들에 포함됨.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# 서버 전용. RLS 우회. NEXT_PUBLIC_ 접두사 절대 금지.
SUPABASE_SERVICE_ROLE_KEY=

# ============================================================
# 관리자 (선택)
# ============================================================
# 콤마 구분 이메일 목록. 미지정 시 기본 ysong2526@gmail.com (lib/admin.ts).
ADMIN_EMAILS=
# 클라이언트(게시판 글쓰기/수정 페이지)용. 보안 가드는 서버측 ADMIN_EMAILS가 진짜 권한.
NEXT_PUBLIC_ADMIN_EMAILS=

# ============================================================
# Upstash Redis — Rate Limiting (선택)
# ============================================================
# https://upstash.com → Create Database → Region: Asia Pacific 권장 → Copy REST URL/Token
# 미설정 시 lib/rate-limit.ts가 graceful fallback (rate-limit no-op, 인증/zod는 그대로 동작).
# 운영 환경에서는 비용 폭탄 방어를 위해 설정 강력 권장.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ============================================================
# 외부 API
# ============================================================
# Gemini (AI 조언, OCR)
GEMINI_API_KEY=

# 국세청 사업자등록 상태 조회 (data.go.kr)
NTS_API_KEY=

# 소상공인시장진흥공단 - 전통시장 가맹점 (data.go.kr)
MARKET_API_KEY=

# 건강보험심사평가원 - 약국/병원 (data.go.kr). 약국·병원 라우트가 같은 키 사용.
PHARMACY_API_KEY=

# ============================================================
# 사이트 메타 (선택)
# ============================================================
# OpenGraph/sitemap의 기본 URL. 미지정 시 기본 https://taxai.kr.
NEXT_PUBLIC_SITE_URL=
